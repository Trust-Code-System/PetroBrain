PB_ENVIRONMENT=dev
# Tier A (hosted) or self_hosted (Tier B, on-prem behind OT DMZ)
PB_LLM_PROVIDER=anthropic
PB_LLM_MODEL=claude-sonnet-4-6
PB_LLM_MAX_TOKENS=2048
# PB_LLM_API_BASE=http://vllm.internal:8000   # set for self_hosted
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                          # embeddings (Tier A)
# Tier B only: separate self-hosted embeddings endpoint; empty = reuse PB_LLM_API_BASE
# PB_EMBEDDING_API_BASE=http://vllm-embed:8000
PB_RERANK_ENABLED=true
PB_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
PB_RERANK_CACHE_DIR=/var/cache/petrobrain
PB_DATABASE_URL=postgresql+asyncpg://petrobrain:petrobrain@localhost:5432/petrobrain
PB_REDIS_URL=redis://localhost:6379/0
PB_REDIS_SSL_CERT_REQS=required              # required | optional | none; used for rediss://
# PB_REDIS_SSL_CA_CERTS=/etc/ssl/certs/ca.pem
PB_AUDIT_LOG_PATH=logs/audit.jsonl
PB_PERSISTENCE_BACKEND=local_json          # local_json | postgres
# Apply schema + RLS to the database above:  python -m app.db.pg
# Run the gated Postgres integration tests against an admin/superuser DSN:
# PB_TEST_DATABASE_URL=postgresql://petrobrain:petrobrain@localhost:5432/petrobrain
PB_MRV_STORE_PATH=data/mrv_inventories.jsonl
PB_DOCUMENT_STORE_PATH=data/document_chunks.jsonl
PB_ADMIN_DOCUMENT_STORE_PATH=data/admin_documents.jsonl
PB_AUDIT_EVENTS_STORE_PATH=data/audit_events.jsonl
PB_ASSETS_STORE_PATH=data/assets.jsonl
PB_ASSET_RELATIONSHIPS_STORE_PATH=data/asset_relationships.jsonl
PB_PERMITS_STORE_PATH=data/permits.jsonl
PB_RESEARCH_STORE_PATH=data/research_runs.jsonl

# Governed Research Mode. Web research remains disabled unless Tavily is configured.
PB_RESEARCH_ENABLED=true
PB_RESEARCH_CONNECTORS_ENABLED=false
PB_RESEARCH_MAX_STEPS=8
PB_RESEARCH_MAX_SOURCES=20
PB_TAVILY_API_KEY=

# Transactional email via Resend (team invitations). Leave PB_RESEND_API_KEY
# blank to keep delivery off (invites still work via the shown secure link).
# The "from" domain must be verified in the Resend dashboard.
PB_RESEND_API_KEY=
PB_INVITE_EMAIL_FROM=PetroBrain <onboarding@petrobrain.xyz>
PB_APP_PUBLIC_BASE_URL=https://petrobrain.xyz

# Async ingestion (A5): object storage + Celery
PB_OBJECT_STORE_BACKEND=s3                  # s3 (MinIO/AWS) or memory (tests)
PB_OBJECT_STORE_ENDPOINT=http://localhost:9000
PB_OBJECT_STORE_REGION=af-south-1
PB_OBJECT_STORE_BUCKET=petrobrain-docs
PB_OBJECT_STORE_ACCESS_KEY=minioadmin          # local MinIO only; leave empty for AWS task-role auth
PB_OBJECT_STORE_SECRET_KEY=minioadmin          # local MinIO only; leave empty for AWS task-role auth
PB_OBJECT_STORE_USE_PATH_STYLE=true
PB_CELERY_BROKER_URL=redis://localhost:6379/1
PB_CELERY_RESULT_BACKEND=redis://localhost:6379/2
PB_CELERY_TASK_ALWAYS_EAGER=false

# Upload malware scanning. Production should run clamd and fail closed.
PB_MALWARE_SCAN_ENABLED=false
PB_MALWARE_SCAN_HOST=
PB_MALWARE_SCAN_PORT=3310
PB_MALWARE_SCAN_TIMEOUT_SECONDS=10
PB_MALWARE_SCAN_FAIL_CLOSED=false

# Observability (A7)
PB_LOG_JSON=true
# PB_OTEL_ENDPOINT=http://localhost:4317
PB_METRICS_ENABLED=true
PB_METRICS_AUTH_TOKEN=                         # required when PB_ENVIRONMENT=prod and metrics are enabled
PB_AUTH_RATE_LIMIT_PER_MINUTE=20
PB_API_RATE_LIMIT_PER_MINUTE=120
PB_UPLOAD_RATE_LIMIT_PER_MINUTE=10
PB_TOKEN_COST_REDIS_ENABLED=false
PB_JWT_SECRET=dev-secret-change-me-32-bytes-minimum
# PB_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----..."
PB_JWT_ISSUER=petrobrain
PB_JWT_AUDIENCE=petrobrain-api
PB_ENABLE_SELF_SIGNUP=true                     # set false in production
PB_INVITATION_EXPIRY_DAYS=7
PB_INVITE_EMAIL_DELIVERY_ENABLED=false         # no email adapter is implemented yet

# Neon Auth (SSO). When enabled, EdDSA bearer tokens minted by Neon Auth are
# verified against Neon's JWKS and mapped to an active users row by the token's
# `sub` (-> users.id), falling back to the `email` claim. Off by default.
PB_NEON_AUTH_ENABLED=false
# Neon "Auth URL" (NO PB_ prefix - matches the web app/Vercel value). The JWKS
# lives at <base>/.well-known/jwks.json. MUST include the `/neondb/auth` path:
# Neon routes by the first path segment as the database name, so dropping it
# makes JWKS resolve against a nonexistent db "api" (Postgres 3D000).
# NEON_AUTH_BASE_URL=https://ep-xxxx.neonauth.<region>.aws.neon.tech/neondb/auth

PB_OPERATIONAL_TIER=false
PB_SOVEREIGN_REGION=af-south-1
